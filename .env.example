# Pixie Configuration Example
# Copy this file to .env and fill in your values

# Solana RPC Endpoint
RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Wallet Private Key (JSON array format)
WALLET_PRIVATE_KEY=[1,2,3,...]

# OpenAI API Key (optional, for advanced NLP)
OPENAI_API_KEY=sk-...

# Jito Block Engine (optional, for MEV protection)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Jupiter API (optional, uses default if not set)
JUPITER_API_ENDPOINT=https://quote-api.jup.ag/v6

# Environment
NODE_ENV=production

# Logging
LOG_LEVEL=info
